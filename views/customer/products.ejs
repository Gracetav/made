<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<main class="mx-auto max-w-6xl px-4 py-8">
  <section class="mb-8 overflow-hidden rounded-3xl border border-blue-300/30 bg-gradient-to-r from-[#102a52] via-[#14366b] to-[#1e3a8a] p-7 shadow-2xl shadow-black/30">
    <p class="text-xs uppercase tracking-[0.2em] text-blue-200/80">Jaya Motospart Collection</p>
    <h1 class="mt-2 text-3xl font-bold md:text-4xl">Premium Sparepart untuk Performa Maksimal</h1>
    <p class="mt-3 max-w-2xl text-sm text-blue-100/90 md:text-base">Pilih komponen terbaik untuk motor kamu. Produk berkualitas, stok terjaga, checkout cepat seperti e-commerce modern.</p>
  </section>

  <section class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
    <% products.forEach((p) => { %>
      <article class="group overflow-hidden rounded-2xl border border-blue-400/30 bg-[#102a52]/85 shadow-xl shadow-black/30 transition hover:-translate-y-1 hover:shadow-blue-900/40">
        <div class="relative h-48 overflow-hidden">
          <img
            class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
            src="<%= p.image || `https://placehold.co/800x600/102a52/e5ecff?text=${encodeURIComponent(p.name)}` %>"
            alt="<%= p.name %>"
          />
          <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-[#102a52] to-transparent"></div>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-semibold"><%= p.name %></h3>
          <p class="mt-2 line-clamp-2 text-sm text-slate-300"><%= p.description %></p>
          <div class="mt-4 flex items-center justify-between">
            <p class="text-xl font-bold text-blue-300">Rp <%= Number(p.price).toLocaleString('id-ID') %></p>
            <a class="inline-block rounded-xl border border-blue-300/50 px-4 py-2 text-sm font-medium hover:bg-blue-900/40" href="/customer/products/<%= p.id %>">Detail</a>
          </div>
        </div>
      </article>
    <% }) %>
  </section>
</main>
<%- include('../partials/foot') %>
