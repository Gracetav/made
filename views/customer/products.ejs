<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<main class="mx-auto max-w-6xl px-4 py-8">
  <h1 class="mb-6 text-3xl font-bold">Sparepart Products</h1>
  <section class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
    <% products.forEach((p) => { %>
      <article class="rounded-2xl border border-blue-400/30 bg-[#102a52]/80 p-5 shadow-lg shadow-black/30">
        <h3 class="text-lg font-semibold"><%= p.name %></h3>
        <p class="mt-2 line-clamp-3 text-sm text-slate-300"><%= p.description %></p>
        <p class="mt-3 text-xl font-bold text-blue-300">Rp <%= Number(p.price).toLocaleString('id-ID') %></p>
        <a class="mt-4 inline-block rounded-xl border border-blue-300/50 px-4 py-2 text-sm font-medium hover:bg-blue-900/40" href="/customer/products/<%= p.id %>">Detail</a>
      </article>
    <% }) %>
  </section>
</main>
<%- include('../partials/foot') %>
