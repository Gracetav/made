<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<main class="mx-auto max-w-6xl px-4 py-8">
  <% const detailImage = (product.image && String(product.image).trim() !== '') ? product.image : `https://placehold.co/1000x800/102a52/ffffff?text=${encodeURIComponent(product.name)}`; %>
  <section class="grid gap-6 rounded-2xl border border-blue-400/30 bg-[#102a52]/80 p-5 shadow-2xl shadow-black/30 md:grid-cols-2 md:p-6">
    <div class="overflow-hidden rounded-2xl border border-blue-300/20 bg-blue-950/30">
      <img
        class="h-full w-full object-cover"
        src="<%= detailImage %>"
        alt="<%= product.name %>"
        onerror="this.src='https://placehold.co/1000x800/102a52/ffffff?text=No+Image';"
      />
    </div>
    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-blue-200/80">Product Detail</p>
      <h1 class="mt-2 text-3xl font-bold text-white"><%= product.name %></h1>
      <p class="mt-3 text-white/90"><%= product.description %></p>
      <div class="mt-5 flex flex-wrap gap-3 text-white">
        <span class="rounded-full bg-blue-900/50 px-3 py-1 text-xs text-blue-100">Stock: <%= product.stock %></span>
        <span class="rounded-full bg-indigo-900/50 px-3 py-1 text-xs text-indigo-100">Original Part</span>
      </div>
      <p class="mt-5 text-3xl font-bold text-blue-300">Rp <%= Number(product.price).toLocaleString('id-ID') %></p>
      <form method="POST" action="/customer/cart" class="mt-6 flex flex-wrap items-center gap-3">
        <input type="hidden" name="product_id" value="<%= product.id %>" />
        <input class="w-24 rounded-xl border border-blue-300/40 bg-blue-950/40 px-3 py-2 outline-none ring-blue-400 focus:ring" type="number" name="qty" min="1" value="1" required />
        <button class="rounded-xl bg-primary px-5 py-2.5 font-semibold hover:bg-blue-700" type="submit">Tambah ke Cart</button>
      </form>
    </div>
  </section>
</main>
<%- include('../partials/foot') %>
