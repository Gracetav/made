<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<main class="mx-auto max-w-3xl px-4 py-8">
  <section class="rounded-2xl border border-blue-400/30 bg-[#102a52]/80 p-6 shadow-xl shadow-black/30">
    <h1 class="text-3xl font-bold">Upload Bukti Transfer</h1>
    <p class="mt-2 text-sm text-slate-300">Order kamu sudah dibuat. Silakan upload bukti transfer untuk lanjut ke invoice.</p>

    <div class="mt-4 rounded-xl border border-blue-300/25 bg-blue-950/30 p-4 text-sm">
      <p><span class="text-slate-400">Invoice:</span> <span class="font-semibold text-white"><%= order.invoice_number %></span></p>
      <p class="mt-1"><span class="text-slate-400">Total:</span> <span class="font-semibold text-blue-300">Rp <%= Number(order.total).toLocaleString('id-ID') %></span></p>
    </div>

    <form class="mt-6 space-y-3 rounded-xl border border-blue-300/25 p-4" method="POST" action="/orders/upload-proof/<%= order.id %>" enctype="multipart/form-data">
      <label class="text-sm text-slate-300">Pilih gambar bukti transfer (jpg/png/webp)</label>
      <input class="w-full rounded-xl border border-blue-300/40 bg-blue-950/40 px-4 py-3 outline-none ring-blue-400 focus:ring" type="file" name="payment_proof" accept="image/*" required />
      <button class="rounded-xl bg-primary px-5 py-2.5 font-semibold hover:bg-blue-700" type="submit">Kirim Bukti Transfer</button>
    </form>
  </section>
</main>
<%- include('../partials/foot') %>
